# API Keys Configuration for Task Master AI
# Copy this file to .env and fill in your actual API keys
# NEVER commit .env to version control!

# Anthropic Claude API (Required for main model)
ANTHROPIC_API_KEY="sk-ant-api03-..."

# Perplexity API (Optional, for research mode)
PERPLEXITY_API_KEY="pplx-..."

# OpenAI API (Optional, for GPT models)
OPENAI_API_KEY="sk-proj-..."

# Google Gemini API (Optional)
GOOGLE_API_KEY="AIzaSy..."

# Mistral API (Optional)
MISTRAL_API_KEY="your_mistral_key_here"

# xAI API (Optional)
XAI_API_KEY="your_xai_key_here"

# Groq API (Optional)
GROQ_API_KEY="your_groq_key_here"

# OpenRouter API (Optional)
OPENROUTER_API_KEY="your_openrouter_key_here"

# Azure OpenAI (Optional)
AZURE_OPENAI_API_KEY="your_azure_key_here"

# Ollama (Optional, for local models)
OLLAMA_API_KEY="your_ollama_api_key_here"

# GitHub (Optional, for GitHub features)
GITHUB_API_KEY="ghp_... or github_pat_..."
